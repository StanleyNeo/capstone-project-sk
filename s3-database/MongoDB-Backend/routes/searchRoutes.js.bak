const express = require('express');
const router = express.Router();
const Course = require('../models/Course');

// Search courses
router.post('/search', async (req, res) => {
  try {
    const { query } = req.body;
    
    if (!query || query.trim().length < 2) {
      return res.status(400).json({
        success: false,
        error: 'Please enter at least 2 characters'
      });
    }

    const searchQuery = query.trim();
    
    // MongoDB text search
    const courses = await Course.find({
      $or: [
        { title: { $regex: searchQuery, $options: 'i' } },
        { description: { $regex: searchQuery, $options: 'i' } },
        { category: { $regex: searchQuery, $options: 'i' } },
        { instructor: { $regex: searchQuery, $options: 'i' } }
      ]
    }).limit(10);

    res.json({
      success: true,
      results: courses,
      count: courses.length,
      query: searchQuery
    });

  } catch (error) {
    console.error('Search error:', error);
    res.status(500).json({
      success: false,
      error: 'Search failed',
      results: []
    });
  }
});

// Alternative: Simple search endpoint
router.get('/search/simple', async (req, res) => {
  try {
    const { q } = req.query;
    
    if (!q) {
      return res.status(400).json({
        success: false,
        error: 'Query parameter is required'
      });
    }

    const courses = await Course.find({
      $or: [
        { title: { $regex: q, $options: 'i' } },
        { description: { $regex: q, $options: 'i' } }
      ]
    }).limit(5);

    res.json({
      success: true,
      courses,
      count: courses.length
    });

  } catch (error) {
    console.error('Simple search error:', error);
    res.status(500).json({
      success: false,
      error: 'Search failed',
      courses: []
    });
  }
});

// Get search suggestions
router.get('/suggestions', async (req, res) => {
  try {
    const { q } = req.query;
    
    if (!q || q.length < 2) {
      return res.json({
        success: true,
        suggestions: []
      });
    }

    const queryLower = q.toLowerCase();
    const courses = await getCourses();
    
    // Get unique categories
    const categories = [...new Set(courses.map(c => {
      const courseData = c.toObject ? c.toObject() : c;
      return courseData.category;
    }))];
    
    // Get popular search terms
    const popularTerms = [
      ...categories,
      'Python',
      'JavaScript',
      'React',
      'AI',
      'Machine Learning',
      'Data Science',
      'Web Development',
      'Beginner',
      'Advanced',
      'Design',
      'Programming',
      'Full Stack',
      'UI/UX',
      'Database',
      'Node.js'
    ];

    // Filter suggestions
    const suggestions = popularTerms
      .filter(term => term.toLowerCase().includes(queryLower))
      .slice(0, 8);

    // Add course title suggestions
    const courseSuggestions = courses
      .filter(course => {
        const courseData = course.toObject ? course.toObject() : course;
        return courseData.title?.toLowerCase().includes(queryLower);
      })
      .map(course => {
        const courseData = course.toObject ? course.toObject() : course;
        return courseData.title;
      })
      .slice(0, 4);

    const allSuggestions = [...new Set([...suggestions, ...courseSuggestions])];

    res.json({
      success: true,
      suggestions: allSuggestions.slice(0, 10),
      total: allSuggestions.length
    });

  } catch (error) {
    console.error('Suggestions error:', error);
    res.status(500).json({
      success: false,
      suggestions: []
    });
  }
});



module.exports = router;